# ─── PostgreSQL ────────────────────────────────────────────────────────
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:123456@localhost:5432/DB_EDScript"

# ─── Servidor ─────────────────────────────────────────────────────────
PORT=3001

# ─── CORS (URL do frontend) ──────────────────────────────────────────
FRONTEND_URL="http://localhost:8080"

# ─── n8n Webhook (opcional — para validar chamadas) ───────────────────
N8N_WEBHOOK_SECRET=""

# ─── BestAPI (Jogos) ───────────────────
BETSAPI_TOKEN=""