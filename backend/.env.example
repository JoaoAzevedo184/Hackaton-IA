# ─── PostgreSQL ────────────────────────────────────────────────────────
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/esportes_da_sorte"

# ─── Servidor ─────────────────────────────────────────────────────────
PORT=3001

# ─── CORS (URL do frontend) ──────────────────────────────────────────
FRONTEND_URL="http://localhost:8080"

# ─── n8n Webhook (opcional — para validar chamadas) ───────────────────
N8N_WEBHOOK_SECRET=""
